<c:EDDControl x:Class="EEDD.Controls.EDDTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:c="clr-namespace:EEDD.Controls"
             xmlns:l="clr-namespace:EEDD"
             mc:Ignorable="d"
             d:DesignHeight="20" d:DesignWidth="35" d:Background="{x:Static l:EDDBrushes.BackgroundGray1}" PreviewMouseDoubleClick="UserControl_PreviewMouseDoubleClick" PreviewMouseDown="UserControl_PreviewMouseDown">
    <UserControl.Resources>
        <Style x:Key="Label" TargetType="{x:Type Label}">
            <Setter Property="Padding" Value="3,0,3,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Border BorderBrush="Black" BorderThickness="0.5" />
        <Rectangle x:Name="focusBorder" Visibility="Collapsed" Stroke="Black" StrokeThickness="1" StrokeDashArray="3 3" Margin="1.5" />
        <Label x:Name="textLabel" Content="{Binding Text, Mode=OneWay}" Style="{StaticResource Label}" Margin="0,-1,0,0" ToolTip="{Binding Caption, Mode=OneWay}" Foreground="{Binding ForeColor, Mode=OneWay}" HorizontalContentAlignment="{Binding Align, Mode=OneTime}" />
        <Canvas x:Name="acceptRectangle" Visibility="Collapsed" HorizontalAlignment="Right" Width="1.5" Background="{x:Static l:EDDBrushes.DarkGreen}" Margin="2" />
        <Polygon x:Name="requestArrow" Points="0,0 4,0, 4,4" Visibility="Collapsed" Fill="{x:Static l:EDDBrushes.LightBlue}" HorizontalAlignment="Right" Margin="2" />
        <TextBox x:Name="textBox" Visibility="Collapsed" BorderBrush="Gray" BorderThickness="0.5" MaxLength="{Binding MaxLength, Mode=OneWay}" Text="{Binding Text, Mode=TwoWay}" FontFamily="Segoe UI" FontSize="12" Padding="0,1" HorizontalContentAlignment="Left" KeyDown="TextBox_KeyDown" MouseDown="TextBox_MouseDown" LostMouseCapture="TextBox_LostMouseCapture" />
    </Grid>
</c:EDDControl>
