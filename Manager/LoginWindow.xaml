<Window x:Class="Manager.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Manager"
        mc:Ignorable="d" SizeToContent="Height"
        Title="Přihlásit se..." Width="250" ResizeMode="NoResize">
    <StackPanel Margin="10">
        <Label Content="Uživatelské jméno:" Padding="2" />
        <TextBox x:Name="Username" />
        <Label Content="Heslo:" Padding="2" Margin="0,10,0,0" />
        <PasswordBox x:Name="Password" />
        <Button x:Name="LoginButton" Content="Přihlásit se" Margin="0,10,0,0" Padding="2" Click="LoginButton_Click" />
    </StackPanel>
</Window>
